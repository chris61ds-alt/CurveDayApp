{
  "expo": {
    "name": "CurveDay",
    "slug": "curveday",
    "scheme": "curveday",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060b13"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.curveday.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060b13"
      },
      "package": "com.curveday.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#38bdf8"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "925886f5-b140-4076-80b5-503bd295011e"
      }
    }
  }
}
